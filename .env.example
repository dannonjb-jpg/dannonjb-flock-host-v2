# ── Brain (REQUIRED) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Path to the SOUL contract. Copy flock-soul-contract.md into the project root.
SOUL_CONTRACT_PATH=./flock-soul-contract.md
# Pricing tables appended to the system prompt. Brain quotes from here; host charges from pricing.ts.
# They are derived from the same source — keep them in sync when prices change.
PRICING_PATH=./flock-soul-pricing.md
MAX_TOKENS=2048

# ── Storage + WhatsApp ───────────────────────────────────────────────────────
DB_PATH=./flock.db
WA_AUTH_DIR=./wa-auth

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_TEST_MODE=true
DEFAULT_PAYMENT_METHOD=stripe

# ── Operator notifications (Flock's OWN bot — NOT Penn's token) ──────────────
# Create via BotFather: /newbot → copy token here.
# Penn's token is in openclaw.json — Flock must never share it (polling race).
TELEGRAM_FLOCK_BOT_TOKEN=
TELEGRAM_CHAT_ID=7111609127

# ── Test / reset ─────────────────────────────────────────────────────────────
# Dan's personal WhatsApp number in Baileys format. Reset command is gated to this JID only.
# STRIPE_TEST_MODE must be true for reset to work.
TEST_JID=+1...@s.whatsapp.net

# ── External integrations ────────────────────────────────────────────────────
# MOCKUP_URL: HTTP endpoint of flock_mockup_worker.py (check what port it listens on)
MOCKUP_URL=
SUPPLIER_QUEUE_URL=
DELIVERY_URL=

# ── Loop intervals (ms) ──────────────────────────────────────────────────────
SCHEDULER_MS=3600000
HEARTBEAT_MS=900000
